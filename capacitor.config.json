{
  "appId": "com.nunziodiet.app",
  "appName": "NunzioDiet",
  "webDir": "docs",
  "android": {
    "minWebViewVersion": 88,
    "backgroundColor": "#0b0718"
  },
  "ios": {
    "backgroundColor": "#0b0718"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0b0718",
      "splashFullScreen": true,
      "splashImmersive": true,
      "layoutName": "launch_screen",
      "useDialog": false
    }
  }
}
